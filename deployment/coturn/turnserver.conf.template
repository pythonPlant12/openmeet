# CoTURN Configuration for OpenMeet

listening-ip=0.0.0.0
listening-port=3478
tls-listening-port=5349

# Relay ports
min-port=49152
max-port=65535

# Realm
realm=${TURN_REALM}
server-name=turn.${DOMAIN}

# Authentication
user=${TURN_USER}:${TURN_PASSWORD}

# External IP
external-ip=${VPS_IP}

# Logging
verbose

# Security
fingerprint
lt-cred-mech
no-tcp-relay
no-cli

# Allow all peer IPs (including Docker internal networks)
# For production behind NAT, TURN needs to relay to container IPs
